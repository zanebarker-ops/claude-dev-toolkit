{
  "description": "PR Review Toolkit hooks - reminds to run review before PR creation",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-pr-check.sh"
          }
        ]
      }
    ]
  }
}
